{
  "name": "tokenfc",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:api": "pnpm --filter @tokenfc/api dev",
    "dev:web": "pnpm --filter @tokenfc/web dev",
    "dev:worker": "pnpm --filter @tokenfc/worker dev",
    "lint": "pnpm -r --if-present lint",
    "db:generate": "pnpm --filter @tokenfc/db prisma generate",
    "db:migrate": "pnpm --filter @tokenfc/db prisma migrate dev",
    "db:seed": "pnpm --filter @tokenfc/db seed"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
